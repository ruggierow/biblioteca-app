{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Biblioteca 0.4.9",
  "version": "0.4.9",
  "identifier": "com.ruggierow.biblioteca",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sistema de Gestão de Biblioteca v0.4.9",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "center": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
